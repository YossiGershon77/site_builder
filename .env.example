# Supabase / PostgreSQL connection strings
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# Domain used for subdomain extraction
# In production: "yourdomain.com"
# In development: "localhost" (subdomains via slug.localhost:3000)
NEXT_PUBLIC_SITE_DOMAIN="localhost:3000"

# Fallback slug for local development when no subdomain is present
DEMO_SLUG="eduardo"
